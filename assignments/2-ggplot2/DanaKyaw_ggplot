dt_year <- dt_mon[, .(
  prec_year = sum(VALUE, na.rm = TRUE)),
  
  by = .(Station = STATION,
         Year = year(DT))]

dt_year


##  Part09 -- Grammar of Graphics Explanations

    
##  Datetime(DT) and Value are mapped inside aes()
##  I used geom_lines, geom_points, geom_histograms, geom_boxplots, and geom_bar chart.
##  I used facet_wrap to split the data into separate panels for each station and it is more clearly compared comparison.
##  theme_bw is used to improve clarity, reduce visual clutter, and enhance readability.



##  Part11 -- Reshape Task

dt_re <- dcast(dt_year, Station ~ Year, value.var = "prec_year")



##  Part12 -- Multi-panel final figure

Four_panel <- (p2 | p3) /
  (p4 | p6)



##  Part13 -- Saving output

ggsave(
  filename = "fig_monthly_precipitation.png",
  plot = p2,
  width = 10,
  height = 6,
  dpi = 300
)

ggsave(
  filename = "fig_extremes.png",
  plot = p3,
  width = 10,
  height = 6,
  dpi = 300
)

ggsave(
  filename = "fig_comparison.png",
  plot = Four_panel,
  width = 12,
  height = 6,
  dpi = 300
)


